# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Scoring provider: tfidf (default), claude, gemini, huggingface
SCORING_PROVIDER=tfidf

# Optional: provider API keys (only needed for non-tfidf providers)
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
HUGGINGFACE_API_KEY=

# Scheduler
SCRAPE_INTERVAL_HOURS=6

# Logging
LOG_LEVEL=INFO

# Optional: override proxy source URLs
# PROXYSCRAPE_URL=https://api.proxyscrape.com/v3/free-proxy-list/get?...
# GEONODE_URL=https://proxylist.geonode.com/api/proxy-list?...
