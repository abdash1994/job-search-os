# ─── Supabase (get from https://app.supabase.com → Project Settings → API) ───
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Next.js (same as above, prefixed for client-side exposure) ───────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Scraper settings ─────────────────────────────────────────────────────────
SCRAPE_INTERVAL_HOURS=6
MAX_PROXY_RETRIES=5
REQUEST_DELAY_MIN=2
REQUEST_DELAY_MAX=9
LOG_LEVEL=INFO

# ─── Scoring provider (swap to claude|gemini|huggingface when ready) ──────────
SCORING_PROVIDER=tfidf

# ─── Future: paid AI providers (leave blank until you're ready) ───────────────
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
HUGGINGFACE_API_KEY=

# ─── Proxy sources (free, no key needed — kept here for override) ─────────────
PROXYSCRAPE_URL=https://api.proxyscrape.com/v2/?request=displayproxies&protocol=http&timeout=5000&country=all&ssl=all&anonymity=elite
GEONODE_URL=https://proxylist.geonode.com/api/proxy-list?limit=200&page=1&sort_by=lastChecked&sort_type=desc&protocols=http,https
